@@ -0,0 +1,107 @@
+package org.logstash.plugins.pipeline;
+
+import co.elastic.logstash.api.Event;
+import org.junit.Test;
+
+import java.util.Collection;
+import java.util.Collections;
+import java.util.concurrent.CountDownLatch;
+import java.util.concurrent.ExecutorService;
+import java.util.concurrent.Executors;
+import java.util.concurrent.Future;
+import java.util.concurrent.TimeUnit;
+
+import static org.junit.Assert.assertTrue;
+
+public class PipelineBusV2Test {
+
+    @Test
+    public void addressStateMutationDoesNotDeadlockWithListenerMonitorHeld() throws Exception {
+        final PipelineBusV2.AddressStateMapping mapping = new PipelineBusV2.AddressStateMapping();
+        final BlockingPipelineInput input = new BlockingPipelineInput("listener");
+        mapping.mutate("address", state -> state.setInput(input));
+
+        final ExecutorService executor = Executors.newFixedThreadPool(2);
+        try {
+            final Future<?> unregisterLikeMutation = executor.submit(() ->
+                mapping.mutate("address", state -> {
+                    input.computeStarted.countDown();
+                    await(input.unlistenEntered);
+                    await(input.releaseCompute);
+                    state.unsetInput(input);
+                })
+            );
+
+            assertTrue(input.computeStarted.await(5, TimeUnit.SECONDS));
+
+            final Future<?> unlistenLikeMutation = executor.submit(() -> {
+                synchronized (input) {
+                    input.unlistenEntered.countDown();
+                    await(input.allowUnlistenMutation);
+                    mapping.mutate("address", state -> state.unsetInput(input));
+                }
+            });
+
+            assertTrue(input.unlistenEntered.await(5, TimeUnit.SECONDS));
+            input.allowUnlistenMutation.countDown();
+            input.releaseCompute.countDown();
+
+            unregisterLikeMutation.get(5, TimeUnit.SECONDS);
+            unlistenLikeMutation.get(5, TimeUnit.SECONDS);
+        } finally {
+            executor.shutdownNow();
+            executor.awaitTermination(5, TimeUnit.SECONDS);
+        }
+    }
+
+    private static void await(final CountDownLatch latch) {
+        try {
+            if (!latch.await(5, TimeUnit.SECONDS)) {
+                throw new AssertionError("timed out waiting for test coordination");
+            }
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+            throw new AssertionError(e);
+        }
+    }
+
+    private static final class BlockingPipelineInput implements PipelineInput {
+        private final String id;
+        private final CountDownLatch computeStarted = new CountDownLatch(1);
+        private final CountDownLatch unlistenEntered = new CountDownLatch(1);
+        private final CountDownLatch allowUnlistenMutation = new CountDownLatch(1);
+        private final CountDownLatch releaseCompute = new CountDownLatch(1);
+
+        private BlockingPipelineInput(final String id) {
+            this.id = id;
+        }
+
+        @Override
+        public String getId() {
+            return id;
+        }
+
+        @Override
+        public ReceiveResponse internalReceive(final Collection<Event> events) {
+            return ReceiveResponse.completed();
+        }
+
+        @Override
+        public boolean isRunning() {
+            return true;
+        }
+
+        @Override
+        public boolean isDeadLetterQueueEnabled() {
+            return false;
+        }
+
+        @Override
+        public void setPipelineMetric(final PipelineMetric pipelineMetric) {
+        }
+
+        @Override
+        public Collection<String> getAddresses() {
+            return Collections.emptyList();
+        }
+    }
