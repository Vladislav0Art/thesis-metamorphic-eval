@@ -0,0 +1,102 @@
+package org.logstash.plugins.pipeline;
+
+import org.junit.Test;
+import org.logstash.ext.JrubyEventExtLibrary;
+
+import java.util.Collections;
+import java.util.concurrent.CountDownLatch;
+import java.util.concurrent.TimeUnit;
+import java.util.concurrent.atomic.AtomicReference;
+import java.util.stream.Stream;
+
+import static org.junit.Assert.assertTrue;
+import static org.junit.Assert.fail;
+
+public class PipelineBusV2Test {
+
+    @Test
+    public void mutateDoesNotHoldAddressLockWhileNotifyingInput() throws Exception {
+        final PipelineBusV2.AddressStateMapping mapping = new PipelineBusV2.AddressStateMapping();
+        final String address = "address";
+        final TestInput input = new TestInput("input");
+        final CountDownLatch firstMutationStarted = new CountDownLatch(1);
+        final CountDownLatch secondMutationFinished = new CountDownLatch(1);
+        final AtomicReference<Throwable> failure = new AtomicReference<>();
+
+        mapping.mutate(address, state -> state.assignInputIfMissing(input));
+
+        synchronized (input) {
+            final Thread firstMutation = new Thread(() -> {
+                try {
+                    mapping.mutate(address, state -> {
+                        firstMutationStarted.countDown();
+                        state.unassignInput(input);
+                    });
+                } catch (Throwable t) {
+                    failure.set(t);
+                }
+            }, "first-mutation");
+            firstMutation.start();
+
+            assertTrue("first mutation should start", firstMutationStarted.await(5, TimeUnit.SECONDS));
+
+            final Thread secondMutation = new Thread(() -> {
+                try {
+                    mapping.mutate(address, state -> state.assignOutput(new TestOutput("output")));
+                    secondMutationFinished.countDown();
+                } catch (Throwable t) {
+                    failure.set(t);
+                }
+            }, "second-mutation");
+            secondMutation.start();
+
+            assertTrue(
+                "second mutation should not be blocked by notification on input monitor",
+                secondMutationFinished.await(5, TimeUnit.SECONDS)
+            );
+
+            firstMutation.join(TimeUnit.SECONDS.toMillis(5));
+            secondMutation.join(TimeUnit.SECONDS.toMillis(5));
+        }
+
+        if (failure.get() != null) {
+            fail("unexpected exception: " + failure.get().getMessage());
+        }
+    }
+
+    private static final class TestInput implements PipelineInput {
+        private final String id;
+
+        private TestInput(final String id) {
+            this.id = id;
+        }
+
+        @Override
+        public ReceiveResponse internalReceive(final Stream<JrubyEventExtLibrary.RubyEvent> events) {
+            return ReceiveResponse.completed();
+        }
+
+        @Override
+        public String getId() {
+            return id;
+        }
+
+        @Override
+        public boolean isRunning() {
+            return true;
+        }
+    }
+
+    private static final class TestOutput implements PipelineOutput {
+        private final String id;
+
+        private TestOutput(final String id) {
+            this.id = id;
+        }
+
+        @Override
+        public String getId() {
+            return id;
+        }
+    }
+}
