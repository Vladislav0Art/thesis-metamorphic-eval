+    @Test
+    public void pipelineBusV2MutateDoesNotDeadlockWhenAnotherMutatorHoldsInputMonitor() throws InterruptedException {
+        Assume.assumeTrue(bus instanceof PipelineBusV2.Testable);
+
+        final PipelineBusV2.AddressStateMapping mapping = new PipelineBusV2.AddressStateMapping();
+        final TestPipelineInput listener = new TestPipelineInput();
+        final TestPipelineOutput sender = new TestPipelineOutput();
+        mapping.mutate(address, (state) -> {
+            state.assignInput(listener);
+            state.assignOutput(sender);
+        });
+
+        final CountDownLatch firstMutatorInside = new CountDownLatch(1);
+        final CountDownLatch allowFirstMutatorToProceed = new CountDownLatch(1);
+        final Thread firstMutator = new Thread(() -> mapping.mutate(address, (state) -> {
+            firstMutatorInside.countDown();
+            try {
+                allowFirstMutatorToProceed.await(5, TimeUnit.SECONDS);
+            } catch (InterruptedException e) {
+                Thread.currentThread().interrupt();
+            }
+            state.unassignOutput(sender);
+        }));
+        firstMutator.setDaemon(true);
+
+        final CountDownLatch secondMutatorHoldingInputLock = new CountDownLatch(1);
+        final Thread secondMutator = new Thread(() -> {
+            synchronized (listener) {
+                secondMutatorHoldingInputLock.countDown();
+                mapping.mutate(address, (state) -> state.assignOutput(sender));
+            }
+        });
+        secondMutator.setDaemon(true);
+
+        firstMutator.start();
+        assertThat(firstMutatorInside.await(5, TimeUnit.SECONDS)).isTrue();
+
+        secondMutator.start();
+        assertThat(secondMutatorHoldingInputLock.await(5, TimeUnit.SECONDS)).isTrue();
+
+        final long secondMutatorBlockedDeadline = System.nanoTime() + Duration.ofSeconds(5).toNanos();
+        while (secondMutator.getState() != Thread.State.BLOCKED && System.nanoTime() < secondMutatorBlockedDeadline) {
+            Thread.sleep(10);
+        }
+        assertThat(secondMutator.getState()).isEqualTo(Thread.State.BLOCKED);
+
+        allowFirstMutatorToProceed.countDown();
+
+        firstMutator.join(Duration.ofSeconds(5).toMillis());
+        secondMutator.join(Duration.ofSeconds(5).toMillis());
+
+        assertThat(firstMutator.getState()).isEqualTo(Thread.State.TERMINATED);
+        assertThat(secondMutator.getState()).isEqualTo(Thread.State.TERMINATED);
+    }
