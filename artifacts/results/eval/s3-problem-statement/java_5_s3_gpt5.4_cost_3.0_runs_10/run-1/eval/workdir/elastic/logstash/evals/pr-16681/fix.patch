@@ -1,4 +1,98 @@
-/*
+package org.logstash.plugins.pipeline;
+
+import org.logstash.ext.JrubyEventExtLibrary;
+import org.junit.Test;
+
+import java.util.concurrent.CountDownLatch;
+import java.util.concurrent.TimeUnit;
+import java.util.concurrent.atomic.AtomicReference;
+import java.util.stream.Stream;
+
+import static org.assertj.core.api.Assertions.assertThat;
+
+public class PipelineBusV2DeadlockTest {
+
+    @Test
+    public void mutateDoesNotDeadlockWhenConcurrentMutationHoldsListenerMonitor() throws Exception {
+        final PipelineBusV2.AddressStateMapping mapping = new PipelineBusV2.AddressStateMapping();
+        final String address = "address";
+        final TestPipelineInput listener = new TestPipelineInput();
+
+        mapping.mutate(address, (addressState) -> addressState.assignInputIfMissing(listener));
+
+        final CountDownLatch firstMutationHoldingMapLock = new CountDownLatch(1);
+        final CountDownLatch secondThreadHoldingListener = new CountDownLatch(1);
+        final CountDownLatch releaseFirstMutation = new CountDownLatch(1);
+        final AtomicReference<Throwable> failure = new AtomicReference<>();
+
+        final Thread firstMutation = new Thread(() -> {
+            try {
+                mapping.mutate(address, (addressState) -> {
+                    firstMutationHoldingMapLock.countDown();
+                    awaitLatch(secondThreadHoldingListener);
+                    awaitLatch(releaseFirstMutation);
+                });
+            } catch (Throwable t) {
+                failure.set(t);
+            }
+        }, "first-mutation");
+        firstMutation.setDaemon(true);
+
+        final Thread secondMutation = new Thread(() -> {
+            try {
+                assertThat(firstMutationHoldingMapLock.await(5, TimeUnit.SECONDS)).isTrue();
+                synchronized (listener) {
+                    secondThreadHoldingListener.countDown();
+                    mapping.mutate(address, (addressState) -> addressState.unassignInput(listener));
+                }
+            } catch (Throwable t) {
+                failure.set(t);
+            }
+        }, "second-mutation");
+        secondMutation.setDaemon(true);
+
+        firstMutation.start();
+        secondMutation.start();
+
+        assertThat(firstMutationHoldingMapLock.await(5, TimeUnit.SECONDS)).isTrue();
+        assertThat(secondThreadHoldingListener.await(5, TimeUnit.SECONDS)).isTrue();
+
+        releaseFirstMutation.countDown();
+
+        firstMutation.join(TimeUnit.SECONDS.toMillis(5));
+        secondMutation.join(TimeUnit.SECONDS.toMillis(5));
+
+        assertThat(failure.get()).isNull();
+        assertThat(firstMutation.isAlive()).isFalse();
+        assertThat(secondMutation.isAlive()).isFalse();
+    }
+
+    private static void awaitLatch(final CountDownLatch latch) {
+        try {
+            assertThat(latch.await(5, TimeUnit.SECONDS)).isTrue();
+        } catch (InterruptedException e) {
+            Thread.currentThread().interrupt();
+            throw new AssertionError(e);
+        }
+    }
+
+    private static final class TestPipelineInput implements PipelineInput {
+        @Override
+        public ReceiveResponse internalReceive(final Stream<JrubyEventExtLibrary.RubyEvent> events) {
+            return ReceiveResponse.completed();
+        }
+
+        @Override
+        public String getId() {
+            return "listener";
+        }
+
+        @Override
+        public boolean isRunning() {
+            return true;
+        }
+    }
+}
