+package org.mockitousage;
+
+import java.util.List;
+import org.junit.jupiter.api.Test;
+import org.junit.jupiter.api.extension.ExtendWith;
+import org.mockito.Spy;
+import org.mockito.junit.jupiter.MockitoExtension;
+
+import static org.junit.jupiter.api.Assertions.assertEquals;
+
+@ExtendWith(MockitoExtension.class)
+class GenericSpyDoesNotCorruptInlineSpyTest {
+
+    @Spy
+    private final List<String> genericSpy = List.of("item A", "item B");
+
+    @Spy
+    private FinalClassWithParameter finalClassWithParameter = new FinalClassWithParameter("some value");
+
+    @Test
+    void should_keep_state_of_inline_spy_when_generic_spy_exists() {
+        assertEquals("some value", finalClassWithParameter.someParameter());
+    }
+
+    static final class FinalClassWithParameter {
+        private final String someParameter;
+
+        FinalClassWithParameter(String someParameter) {
+            this.someParameter = someParameter;
+        }
+
+        String someParameter() {
+            return someParameter;
+        }
+    }
+}
