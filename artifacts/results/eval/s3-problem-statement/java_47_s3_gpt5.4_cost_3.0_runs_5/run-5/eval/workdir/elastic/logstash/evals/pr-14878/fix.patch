+    @Test
+    public void testClosePurgesExpiredSegmentsWithoutNewWrites() throws Exception {
+        final Duration retention = Duration.ofMinutes(1);
+        final java.time.Instant initialNow = java.time.Instant.parse("2023-01-23T12:48:35Z");
+        final java.time.Clock initialClock = java.time.Clock.fixed(initialNow, java.time.ZoneOffset.UTC);
+        final java.time.Instant expiredNow = initialNow.plus(retention).plusSeconds(1);
+        final java.time.Clock expiredClock = java.time.Clock.fixed(expiredNow, java.time.ZoneOffset.UTC);
+
+        try (DeadLetterQueueWriter writer = DeadLetterQueueWriter
+                .newBuilder(dir, 1_000, 1_000_000, Duration.ofHours(1))
+                .retentionTime(retention)
+                .clock(initialClock)
+                .build()) {
+            writer.writeEntry(new DLQEntry(new Event(), "type", "id", "1"));
+        }
+
+        assertTrue(Files.exists(dir.resolve("1.log")));
+
+        try (DeadLetterQueueWriter writer = DeadLetterQueueWriter
+                .newBuilder(dir, 1_000, 1_000_000, Duration.ofHours(1))
+                .retentionTime(retention)
+                .clock(expiredClock)
+                .build()) {
+            assertTrue(Files.exists(dir.resolve("1.log")));
+        }
+
+        assertFalse(Files.exists(dir.resolve("1.log")));
+    }
 
