+    public void testJSONLayoutIgnoresConflictingStructuredMessageField() throws Exception {
+        final ListAppender appender = CTX.getListAppender("JSONEventLogger").clear();
+        final Logger logger = LogManager.getLogger("JSONEventLogger");
+
+        final Map<String, Object> arguments = new LinkedHashMap<>();
+        arguments.put("message", "conflicting structured message");
+        arguments.put("foo", "bar");
+
+        logger.warn("primary message", arguments);
+
+        final List<String> loggedMessages = appender.getMessages();
+        assertEquals(1, loggedMessages.size());
+
+        final String loggedMessage = loggedMessages.get(0);
+        assertEquals(1, loggedMessage.split("\"message\"").length - 1);
+
+        final Map<String, Object> event = ObjectMappers.JSON_MAPPER.readValue(loggedMessage, Map.class);
+        final Map<String, Object> logEvent = (Map<String, Object>) event.get("logEvent");
+
+        assertEquals("primary message", logEvent.get("message"));
+        assertEquals("bar", logEvent.get("foo"));
+        assertEquals(2, logEvent.size());
+    }
