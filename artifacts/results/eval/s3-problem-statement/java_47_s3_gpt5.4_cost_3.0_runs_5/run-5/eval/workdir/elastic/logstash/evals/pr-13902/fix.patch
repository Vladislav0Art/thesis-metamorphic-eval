+    private static final class RetryingFileCheckpointIO extends FileCheckpointIO {
+        private final List<Long> sleepDurations = new ArrayList<>();
+        private int failuresRemaining;
+        private int moveAttempts;
+
+        private RetryingFileCheckpointIO(Path dirPath, boolean retry, int failuresRemaining) {
+            super(dirPath, retry);
+            this.failuresRemaining = failuresRemaining;
+        }
+
+        @Override
+        protected void moveAtomically(Path source, Path target) throws java.io.IOException {
+            moveAttempts++;
+            if (failuresRemaining > 0) {
+                failuresRemaining--;
+                throw new AccessDeniedException(target.toString());
+            }
+            Files.move(source, target, StandardCopyOption.ATOMIC_MOVE);
+        }
+
+        @Override
+        protected void sleepBeforeRetry(long sleepMillis) {
+            sleepDurations.add(sleepMillis);
+        }
+
+        private List<Long> getSleepDurations() {
+            return sleepDurations;
+        }
+
+        private int getMoveAttempts() {
