+        assertThat(Files.exists(checkpointFolder.resolve("checkpoint.head")), is(true));
+    }
+
+    @Test
+    public void writeFailsAfterExhaustingCheckpointMoveRetries() throws Exception {
+        RetryingFileCheckpointIO retryingIo = new RetryingFileCheckpointIO(checkpointFolder, true, 6);
+
+        try {
+            retryingIo.write("checkpoint.head", 6, 2, 10L, 8L, 200);
+            fail("Expected checkpoint move to fail after retries are exhausted");
+        } catch (AccessDeniedException e) {
+            assertThat(retryingIo.getMoveAttempts(), is(6));
+            assertThat(
+                retryingIo.getSleepDurations(),
