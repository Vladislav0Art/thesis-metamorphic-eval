+    @Test
+    public void writeRetriesCheckpointMoveWithExponentialBackoff() throws Exception {
+        RetryingFileCheckpointIO retryingIo = new RetryingFileCheckpointIO(checkpointFolder, true, 2);
+
+        retryingIo.write("checkpoint.head", 6, 2, 10L, 8L, 200);
