       expect(subject.extract("foo||bar")).to eq(["foo"])
     end
   end
+
+  context "with size limit" do
+    subject { FileWatch::BufferedTokenizer.new("\n", limit) }
+
+    let(:limit) { 10 }
+
+    it "drops the oversized buffered token and resumes after the next delimiter" do
+      expect(subject.extract("12345")).to eq([])
+      expect { subject.extract("678901\nabc\n") }.to raise_error(IllegalStateException, "input buffer full")
+      expect(subject.extract("def\n")).to eq(["abc", "def"])
+    end
+
+  end
 end
