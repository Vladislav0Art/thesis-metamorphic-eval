@@ -0,0 +1,22 @@
+package com.alibaba.fastjson2.codec;
+
+import com.alibaba.fastjson2.JSON;
+import org.junit.jupiter.api.Test;
+
+import java.util.Arrays;
+import java.util.List;
+
+import static org.junit.jupiter.api.Assertions.assertSame;
+
+public class RefTest7_arraysList {
+    @Test
+    public void test_ref_arraysList() {
+        String str = "[{\"id\":1},{\"$ref\":\"$[0]\"}]";
+
+        Class<? extends List> arrayListClass = Arrays.asList(1).getClass();
+        List list = JSON.parseObject(str, arrayListClass);
+
+        assertSame(arrayListClass, list.getClass());
+        assertSame(list.get(0), list.get(1));
+    }
+}
