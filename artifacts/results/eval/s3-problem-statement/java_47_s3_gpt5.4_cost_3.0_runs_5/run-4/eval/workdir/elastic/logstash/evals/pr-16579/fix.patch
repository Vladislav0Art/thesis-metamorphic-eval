+
+  context 'with size limit' do
+    subject { FileWatch::BufferedTokenizer.new("\n", 10) }
+
+    it "drops oversized buffered payload and resumes after the next separator" do
+      expect(subject.extract("12345")).to eq([])
+      expect { subject.extract("678901\nok\n") }.to raise_error(java.lang.IllegalStateException, "input buffer full")
+      expect(subject.extract("next\n")).to eq(["next"])
+    end
+  end
 end
