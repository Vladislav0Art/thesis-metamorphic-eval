+  public void testJsonSerializerDeserializerBasedJsonAdapterHonorsNullSafeFalseOnClass() {
+    Gson gson = new Gson();
+    NullAwareSerializerDeserializer.serializeCalled = false;
+    NullAwareSerializerDeserializer.deserializeCalled = false;
+
+    assertEquals("\"serialized-null\"", gson.toJson(null, NullableUser.class));
+    NullableUser user = gson.fromJson("null", NullableUser.class);
+    assertNull(user);
+    assertTrue(NullAwareSerializerDeserializer.serializeCalled);
+    assertTrue(NullAwareSerializerDeserializer.deserializeCalled);
+  }
+
+  @JsonAdapter(value = NullAwareSerializerDeserializer.class, nullSafe = false)
+  private static final class NullableUser {
+  }
+
+  private static final class NullAwareSerializerDeserializer
+      implements JsonSerializer<NullableUser>, JsonDeserializer<NullableUser> {
+    private static boolean serializeCalled;
+    private static boolean deserializeCalled;
+
+    @Override
+    public JsonElement serialize(
+        NullableUser src, Type typeOfSrc, JsonSerializationContext context) {
+      serializeCalled = true;
+      return new JsonPrimitive(src == null ? "serialized-null" : "serialized-non-null");
+    }
+
+    @Override
+    public NullableUser deserialize(
+        JsonElement json, Type typeOfT, JsonDeserializationContext context)
+        throws JsonParseException {
+      deserializeCalled = true;
+      if (json.isJsonNull()) {
+        return null;
+      }
+      return new NullableUser();
+    }
+  }
+
