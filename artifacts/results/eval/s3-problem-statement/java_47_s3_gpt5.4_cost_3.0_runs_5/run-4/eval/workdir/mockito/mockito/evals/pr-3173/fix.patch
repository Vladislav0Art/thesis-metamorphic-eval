index 000000000..d98cbe887
--- /dev/null
+++ b/subprojects/java21/src/test/java/org/mockito/java21/SpyAnnotationOnGenericTypeTest.java
@@ -0,0 +1,36 @@
+/*
+ * Copyright (c) 2024 Mockito contributors
+ * This program is made available under the terms of the MIT License.
+ */
+package org.mockito.java21;
+
+import static org.junit.Assert.assertNotNull;
+
+import java.util.List;
+import org.junit.Test;
+import org.mockito.Mockito;
+import org.mockito.MockitoAnnotations;
+import org.mockito.Spy;
+
+public class SpyAnnotationOnGenericTypeTest {
+
+    @Spy private final List<String> genericSpy = List.of("item A", "item B");
+
+    @Spy private ExampleRecord exampleRecord = new ExampleRecord("some value");
+
+    @Test
+    public void should_keep_preexisting_record_state_when_generic_spy_is_present() throws Exception {
+        try (AutoCloseable ignored = MockitoAnnotations.openMocks(this)) {
+            assertNotNull(exampleRecord.someParameter());
+        }
+    }
+    @Test
+    public void should_keep_preexisting_record_state_when_spying_directly() {
+        Mockito.spy(List.<String>of("item A", "item B"));
+        ExampleRecord exampleRecord = Mockito.spy(new ExampleRecord("some value"));
+
+        assertNotNull(exampleRecord.someParameter());
+    }
+
+    private record ExampleRecord(String someParameter) {}
+}
