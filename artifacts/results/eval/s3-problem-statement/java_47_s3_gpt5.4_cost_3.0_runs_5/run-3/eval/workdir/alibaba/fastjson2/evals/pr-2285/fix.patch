+package com.alibaba.fastjson2.annotation;
+
+import com.alibaba.fastjson2.JSON;
+import com.alibaba.fastjson2.JSONReader;
+import com.alibaba.fastjson2.JSONWriter;
+import com.alibaba.fastjson2.reader.ObjectReader;
+import com.alibaba.fastjson2.writer.ObjectWriter;
+import org.junit.jupiter.api.Test;
+
+import java.lang.reflect.Type;
+
+import static org.junit.jupiter.api.Assertions.assertEquals;
+
+public class JSONType_fieldType {
+    @Test
+    public void testFieldTypeSerializer() {
+        AppDto app = new AppDto();
+        app.alarmStatus = AlarmStatus.RUNNING;
+
+        assertEquals(
+                "{\"alarmStatus\":{\"code\":1}}",
+                JSON.toJSONString(app)
+        );
+    }
+
+    @Test
+    public void testFieldTypeDeserializer() {
+        AppDto app = JSON.parseObject(
+                "{\"alarmStatus\":{\"code\":2}}",
+                AppDto.class
+        );
+
+        assertEquals(AlarmStatus.STOP, app.alarmStatus);
+    }
+
+    public static class AppDto {
+        public AlarmStatus alarmStatus;
+    }
+
+    @JSONType(serializer = AlarmStatusWriter.class, deserializer = AlarmStatusReader.class)
+    public enum AlarmStatus {
+        RUNNING(1),
+        STOP(2);
+
+        public final int code;
+
+        AlarmStatus(int code) {
+            this.code = code;
+        }
+
+        public static AlarmStatus of(int code) {
+            for (AlarmStatus status : values()) {
+                if (status.code == code) {
+                    return status;
+                }
+            }
+            return null;
+        }
+    }
+
+    public static class AlarmStatusWriter
+            implements ObjectWriter<AlarmStatus> {
+        @Override
+        public void write(JSONWriter jsonWriter, Object object, Object fieldName, Type fieldType, long features) {
+            AlarmStatus status = (AlarmStatus) object;
+            jsonWriter.startObject();
+            jsonWriter.writeName("code");
+            jsonWriter.writeColon();
+            jsonWriter.writeInt32(status.code);
+            jsonWriter.endObject();
+        }
+    }
+
+    public static class AlarmStatusReader
+            implements ObjectReader<AlarmStatus> {
+        @Override
+        public AlarmStatus readObject(JSONReader jsonReader, Type fieldType, Object fieldName, long features) {
+            jsonReader.nextIfObjectStart();
+            Integer code = null;
+            for (; ; ) {
+                if (jsonReader.nextIfObjectEnd()) {
+                    break;
+                }
+
+                String name = jsonReader.readFieldName();
+                if ("code".equals(name)) {
+                    code = jsonReader.readInt32();
+                } else {
+                    jsonReader.skipValue();
+                }
+            }
+            jsonReader.nextIfMatch(',');
+
+            return AlarmStatus.of(code);
+        }
+    }
+}
