+package org.logstash.common;
+
+import org.jcodings.specific.ISO8859_1Encoding;
+import org.jruby.RubyArray;
+import org.jruby.RubyString;
+import org.jruby.runtime.ThreadContext;
+import org.junit.Before;
+import org.junit.Test;
+import org.logstash.RubyTestBase;
+import org.logstash.RubyUtil;
+
+import static org.junit.Assert.assertArrayEquals;
+import static org.junit.Assert.assertEquals;
+
+public class BufferedTokenizerExtTest extends RubyTestBase {
+
+    private static final RubyString NEW_LINE = (RubyString) RubyUtil.RUBY.newString("\n")
+            .freeze(RubyUtil.RUBY.getCurrentContext());
+
+    private ThreadContext context;
+    private BufferedTokenizerExt subject;
+
+    @Before
+    public void setUp() {
+        context = RubyUtil.RUBY.getCurrentContext();
+        subject = (BufferedTokenizerExt) RubyUtil.BUFFERED_TOKENIZER.newInstance(
+                context,
+                new org.jruby.runtime.builtin.IRubyObject[] {NEW_LINE},
+                org.jruby.runtime.Block.NULL_BLOCK
+        );
+    }
+
+    @Test
+    public void extractAndFlushPreserveBytesAndEncodingForNonUtf8Data() {
+        RubyString iso88591String = RubyString.newString(RubyUtil.RUBY, new byte[]{(byte) 0xA3});
+        iso88591String.setEncoding(ISO8859_1Encoding.INSTANCE);
+
+        assertEquals(0, subject.extract(context, iso88591String).size());
+
+        RubyString flushed = (RubyString) subject.flush(context);
+        assertArrayEquals(new byte[]{(byte) 0xA3}, flushed.getBytes());
+        assertEquals(ISO8859_1Encoding.INSTANCE, flushed.getEncoding());
+    }
+}
