@@ -184,6 +183,32 @@ public class JsonPointer
         return _nextSegment;
     }
 
+    /**
+     * Accessor for getting the terminal segment of this pointer, if any.
+     * For the empty/root pointer, will return null.
+     *
+     * @since 2.5
+     */
+    public JsonPointer last() {
+        JsonPointer current = this;
+        if (current.matches()) {
+            return null;
+        }
+        while (!current._nextSegment.matches()) {
+            current = current._nextSegment;
+        }
+        return current;
+    }
+
+    /**
+     * Alias for {@link #last()}.
+     *
+     * @since 2.5
+     */
+    public JsonPointer leaf() {
+        return last();
+    }
+
     /**
      * Accessor for getting a "pointer", instance from current segment to
      * segment before segment leaf. For root pointer, will return null.
diff --git a/src/test/java/com/fasterxml/jackson/core/TestJsonPointer.java b/src/test/java/com/fasterxml/jackson/core/TestJsonPointer.java
index 9ef13aa7..5b512a15 100644
--- a/src/test/java/com/fasterxml/jackson/core/TestJsonPointer.java
+++ b/src/test/java/com/fasterxml/jackson/core/TestJsonPointer.java
@@ -102,4 +102,26 @@ public class TestJsonPointer extends BaseTest
         assertTrue(ptr.matches());
         assertNull(ptr.tail());
     }
+
+    public void testLastAndLeaf() throws Exception
+    {
+        JsonPointer ptr = JsonPointer.compile("/score/-");
+        JsonPointer last = ptr.last();
+        assertNotNull(last);
+        assertEquals("/-", last.toString());
+        assertEquals("-", last.getMatchingProperty());
+        assertEquals(-1, last.getMatchingIndex());
+        assertTrue(last.tail().matches());
+
+        JsonPointer leaf = ptr.leaf();
+        assertNotNull(leaf);
+        assertEquals(last, leaf);
+
+        JsonPointer single = JsonPointer.compile("/score");
+        assertEquals("/score", single.last().toString());
+        assertEquals("/score", single.leaf().toString());
+
+        assertNull(JsonPointer.compile("").last());
+        assertNull(JsonPointer.compile("").leaf());
+    }
 }
