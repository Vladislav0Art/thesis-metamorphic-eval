--- /dev/null
+++ b/logstash-core/src/test/java/org/logstash/common/BufferedTokenizerExtTest.java
@@ -0,0 +1,34 @@
+package org.logstash.common;
+
+import org.jruby.RubyArray;
+import org.jruby.RubyString;
+import org.jruby.runtime.ThreadContext;
+import org.junit.Test;
+import org.logstash.RubyTestBase;
+import org.logstash.RubyUtil;
+
+import static org.junit.Assert.assertArrayEquals;
+import static org.junit.Assert.assertTrue;
+
+public class BufferedTokenizerExtTest extends RubyTestBase {
+
+    @Test
+    public void testExtractAndFlushPreserveInputEncodingBytes() {
+        final ThreadContext context = RubyUtil.RUBY.getCurrentContext();
+        final BufferedTokenizerExt tokenizer = new BufferedTokenizerExt(
+            RubyUtil.RUBY, RubyUtil.BUFFERED_TOKENIZER
+        );
+        tokenizer.init(context, new org.jruby.runtime.builtin.IRubyObject[0]);
+
+        final RubyString rubyString = RubyString.newString(RubyUtil.RUBY, new byte[]{(byte) 0xA3});
+        final RubyString encoded = (RubyString) rubyString.force_encoding(
+            context, RubyUtil.RUBY.newString("ISO8859-1")
+        );
+
+        final RubyArray<?> extracted = tokenizer.extract(context, encoded);
+        assertTrue(extracted.isEmpty());
+
+        final RubyString flushed = (RubyString) tokenizer.flush(context);
+        assertArrayEquals(new byte[]{(byte) 0xA3}, flushed.getBytes());
+    }
+}
