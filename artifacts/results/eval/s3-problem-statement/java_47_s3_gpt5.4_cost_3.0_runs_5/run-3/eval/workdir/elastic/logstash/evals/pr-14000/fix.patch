@@ -542,6 +541,30 @@ module LogStash
       end
     end
 
+    class ComplexPassword < Password
+      MINIMUM_LENGTH = 8
+
+      def validate(value)
+        super(value)
+
+        password = value.value
+        return if password.nil?
+        return if complex_enough?(password)
+
+        raise ArgumentError.new("Setting `#{name}` must be at least #{MINIMUM_LENGTH} characters long and include at least one lowercase letter, one uppercase letter, one digit, and one symbol")
+      end
+
+      private
+
+      def complex_enough?(password)
+        password.length >= MINIMUM_LENGTH &&
+          password.match?(/[[:lower:]]/) &&
+          password.match?(/[[:upper:]]/) &&
+          password.match?(/\d/) &&
+          password.match?(/[^[:alnum:]]/)
+      end
+    end
+
     # The CoercibleString allows user to enter any value which coerces to a String.
     # For example for true/false booleans; if the possible_strings are ["foo", "true", "false"]
     # then these options in the config file or command line will be all valid: "foo", true, false, "true", "false"
diff --git a/logstash-core/spec/logstash/settings/password_spec.rb b/logstash-core/spec/logstash/settings/password_spec.rb
index ca90bc4f9..55cde1df6 100644
--- a/logstash-core/spec/logstash/settings/password_spec.rb
+++ b/logstash-core/spec/logstash/settings/password_spec.rb
@@ -61,3 +61,41 @@ describe LogStash::Setting::Password do
     end
   end
 end
+
+describe LogStash::Setting::ComplexPassword do
+  let(:setting_name) { "api.auth.basic.password" }
+  subject(:password_setting) { described_class.new(setting_name, nil, true) }
+
+  context "when set to a sufficiently complex password" do
+    let(:setting_value) { "Str0ng!Pass" }
+
+    before(:each) { password_setting.set(setting_value) }
+
+    it "is valid" do
+      expect { password_setting.validate_value }.not_to raise_error
+      expect(password_setting.value.value).to eq(setting_value)
+    end
+  end
+
+  context "when set to a weak password" do
+    let(:setting_value) { "stashy" }
+
+    before(:each) { password_setting.set(setting_value) }
+
+    it "rejects the value" do
+      expect { password_setting.validate_value }.to raise_error(
+        ArgumentError,
+        "Setting `#{setting_name}` must be at least 8 characters long and include at least one lowercase letter, one uppercase letter, one digit, and one symbol"
+      )
+    end
+  end
+
+  context "when nullable and unset" do
+    subject(:password_setting) { described_class.new(setting_name, nil, true).nullable }
+
+    it "is valid" do
+      expect { password_setting.validate_value }.not_to raise_error
+      expect(password_setting.value).to be_nil
+    end
+  end
+end
