+  public void testJsonAdapterNullSafeFalseForSerializerDeserializer() {
+    Gson gson = new Gson();
+
+    String serialized = gson.toJson(new NullSafeFalseContainer(null));
+    assertEquals("{\"value\":\"serializer-called\"}", serialized);
+
+    NullSafeFalseContainer deserialized =
+        gson.fromJson("{\"value\":null}", NullSafeFalseContainer.class);
+    assertNotNull(deserialized.value);
+    assertEquals("deserializer-called", deserialized.value.name);
+  }
+
+  private static final class NullSafeFalseContainer {
+    @JsonAdapter(value = NullSafeFalseAdapter.class, nullSafe = false)
+    final NullableUser value;
+
+    NullSafeFalseContainer(NullableUser value) {
+      this.value = value;
+    }
+  }
+
+  private static final class NullableUser {
+    final String name;
+
+    NullableUser(String name) {
+      this.name = name;
+    }
+  }
+
+  private static final class NullSafeFalseAdapter
+      implements JsonSerializer<NullableUser>, JsonDeserializer<NullableUser> {
+    @Override
+    public JsonElement serialize(
+        NullableUser src, Type typeOfSrc, JsonSerializationContext context) {
+      return new JsonPrimitive(src == null ? "serializer-called" : src.name);
+    }
+
+    @Override
+    public NullableUser deserialize(
+        JsonElement json, Type typeOfT, JsonDeserializationContext context)
+        throws JsonParseException {
+      if (json.isJsonNull()) {
+        return new NullableUser("deserializer-called");
+      }
+      return new NullableUser(json.getAsString());
+    }
+  }
+
