+    @Test
+    public void writeFailsAfterExhaustingCheckpointMoveRetries() throws Exception {
+        RetryingFileCheckpointIO retryingIo = new RetryingFileCheckpointIO(checkpointFolder, 6, 5);
+
+        try {
+            retryingIo.write("checkpoint.head", 6, 2, 10L, 8L, 200);
