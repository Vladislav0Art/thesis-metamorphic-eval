+    private static final class RetryingFileCheckpointIO extends FileCheckpointIO {
+        private final int failuresBeforeSuccess;
+        private int moveAttempts = 0;
+        private final List<Long> sleepCalls = new ArrayList<>();
+
+        private RetryingFileCheckpointIO(Path dirPath, int failuresBeforeSuccess, int retryAttempts) {
+            super(dirPath, true, retryAttempts, 10L);
+            this.failuresBeforeSuccess = failuresBeforeSuccess;
+        }
+
+        @Override
+        protected void move(Path source, Path target) throws IOException {
+            moveAttempts++;
+            if (moveAttempts <= failuresBeforeSuccess) {
+                throw new AccessDeniedException(target.toString());
+            }
+            Files.move(source, target);
+        }
+
+        @Override
+        protected void sleep(long millis) {
+            sleepCalls.add(millis);
+        }
+
+        private int getMoveAttempts() {
+            return moveAttempts;
+        }
+
+        private List<Long> getSleepCalls() {
+            return sleepCalls;
+        }
