+    @Test
+    public void addressStateMutateDoesNotDeadlockWhenNotificationContendsWithMutation() throws InterruptedException {
+        if (!PipelineBusV2.Testable.class.equals(busClass)) {
+            return;
+        }
+
+        final PipelineBusV2.AddressStateMapping mapping = new PipelineBusV2.AddressStateMapping();
+        mapping.mutate(address, (addressState) -> addressState.assignInputIfMissing(input));
+
+        final CountDownLatch firstMutationEntered = new CountDownLatch(1);
+        final CountDownLatch listenerLockHeld = new CountDownLatch(1);
+        final CountDownLatch secondMutationAttempting = new CountDownLatch(1);
+        final CountDownLatch allowFirstMutationToFinish = new CountDownLatch(1);
+        final List<Throwable> failures = Collections.synchronizedList(new ArrayList<>());
+
+        final Thread firstMutationThread = new Thread(() -> {
+            try {
+                mapping.mutate(address, (addressState) -> {
+                    firstMutationEntered.countDown();
+                    try {
+                        allowFirstMutationToFinish.await();
+                    } catch (InterruptedException e) {
+                        throw new AssertionError(e);
+                    }
+                });
+            } catch (Throwable t) {
+                failures.add(t);
+            }
+        });
+        firstMutationThread.setDaemon(true);
+
+        final Thread secondMutationThread = new Thread(() -> {
+            try {
+                synchronized (input) {
+                    listenerLockHeld.countDown();
+                    firstMutationEntered.await();
+                    secondMutationAttempting.countDown();
+                    mapping.mutate(address, (addressState) -> { });
+                }
+            } catch (Throwable t) {
+                failures.add(t);
+            }
+        });
+        secondMutationThread.setDaemon(true);
+
+        firstMutationThread.start();
+        assertThat(firstMutationEntered.await(5, TimeUnit.SECONDS)).isTrue();
+
+        secondMutationThread.start();
+        assertThat(listenerLockHeld.await(5, TimeUnit.SECONDS)).isTrue();
+        assertThat(secondMutationAttempting.await(5, TimeUnit.SECONDS)).isTrue();
+
+        allowFirstMutationToFinish.countDown();
+
+        firstMutationThread.join(Duration.ofSeconds(5).toMillis());
+        secondMutationThread.join(Duration.ofSeconds(5).toMillis());
+
+        assertThat(failures).isEmpty();
+        assertThat(firstMutationThread.getState()).isEqualTo(Thread.State.TERMINATED);
+        assertThat(secondMutationThread.getState()).isEqualTo(Thread.State.TERMINATED);
+    }
