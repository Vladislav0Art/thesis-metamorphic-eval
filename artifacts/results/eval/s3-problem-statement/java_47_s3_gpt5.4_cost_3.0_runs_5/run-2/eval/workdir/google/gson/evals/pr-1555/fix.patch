+  public void testJsonAdapterNullSafeFalseForSerializerDeserializer() {
+    Gson gson = new Gson();
+
+    assertEquals("\"serialized-null\"", gson.toJson(null, User3.class));
+    assertEquals("deserialized-null", gson.fromJson("null", User3.class).name);
+  }
+
+  @JsonAdapter(value = UserSerializerDeserializer3.class, nullSafe = false)
+  private static final class User3 {
+    public final String name;
+    private User3(String name) {
+      this.name = name;
+    }
+  }
+
+  private static final class UserSerializerDeserializer3
+      implements JsonSerializer<User3>, JsonDeserializer<User3> {
+    @Override
+    public JsonElement serialize(User3 src, Type typeOfSrc, JsonSerializationContext context) {
+      return new JsonPrimitive(src == null ? "serialized-null" : src.name);
+    }
+
+    @Override
+    public User3 deserialize(JsonElement json, Type typeOfT, JsonDeserializationContext context)
+        throws JsonParseException {
+      return new User3(json.isJsonNull() ? "deserialized-null" : json.getAsString());
+    }
+  }
