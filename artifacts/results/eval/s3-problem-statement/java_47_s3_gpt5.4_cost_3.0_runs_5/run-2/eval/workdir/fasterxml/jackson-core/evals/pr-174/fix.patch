diff --git a/src/test/java/com/fasterxml/jackson/core/TestJsonPointer.java b/src/test/java/com/fasterxml/jackson/core/TestJsonPointer.java
index 9ef13aa7..2ff8f8f0 100644
--- a/src/test/java/com/fasterxml/jackson/core/TestJsonPointer.java
+++ b/src/test/java/com/fasterxml/jackson/core/TestJsonPointer.java
@@ -102,4 +102,31 @@ public class TestJsonPointer extends BaseTest
         assertTrue(ptr.matches());
         assertNull(ptr.tail());
     }
+
+    public void testLastSegmentAccess() throws Exception
+    {
+        JsonPointer ptr = JsonPointer.compile("/Image/15/name");
+        JsonPointer last = ptr.last();
+        assertNotNull(last);
+        assertEquals("/name", last.toString());
+        assertEquals("name", last.getMatchingProperty());
+        assertSame(last, ptr.leaf());
+
+        ptr = JsonPointer.compile("/score/-");
+        last = ptr.last();
+        assertNotNull(last);
+        assertEquals("/-", last.toString());
+        assertEquals("-", last.getMatchingProperty());
+        assertSame(last, ptr.leaf());
+
+        ptr = JsonPointer.compile("/score");
+        last = ptr.last();
+        assertNotNull(last);
+        assertEquals("/score", last.toString());
+        assertEquals("score", last.getMatchingProperty());
+
+        ptr = JsonPointer.compile("");
+        assertNull(ptr.last());
+        assertNull(ptr.leaf());
+    }
 }
