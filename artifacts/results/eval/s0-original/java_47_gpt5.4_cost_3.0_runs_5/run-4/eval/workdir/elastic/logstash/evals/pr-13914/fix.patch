diff --git a/build.gradle b/build.gradle
index 7e4c7a868..606e5ee77 100644
--- a/build.gradle
+++ b/build.gradle
@@ -853,6 +853,25 @@ tasks.register("decompressJdk") {
         default:
             dependsOn ":untarJdk"
     }
+
+    doLast {
+        File releaseFile = file(osName == "darwin" ? "${project.ext.jdkBundlingDirectory}/Contents/Home/release" : "${project.ext.jdkBundlingDirectory}/release")
+        if (!releaseFile.exists()) {
+            throw new GradleException("Cannot determine bundled JDK version: missing ${releaseFile}")
+        }
+
+        String implementorVersionLine = releaseFile.readLines().find { it.startsWith("IMPLEMENTOR_VERSION=") }
+        if (implementorVersionLine == null) {
+            throw new GradleException("Cannot determine bundled JDK version: missing IMPLEMENTOR_VERSION in ${releaseFile}")
+        }
+
+        String implementorVersion = implementorVersionLine.split("=", 2)[1].trim()
+        if (implementorVersion.startsWith("\"") && implementorVersion.endsWith("\"")) {
+            implementorVersion = implementorVersion.substring(1, implementorVersion.length() - 1)
+        }
+
+        file("${project.ext.jdkBundlingDirectory}/VERSION").text = "${implementorVersion}\n"
+    }
 }
 
 tasks.register("copyJdk", Copy) {
