+    @Test
+    @SuppressWarnings("unchecked")
+    public void testJSONLayoutDoesNotDuplicateStructuredMessageField() throws Exception {
+        ListAppender appender = CTX.getListAppender("JSONEventLogger").clear();
+        Logger logger = LogManager.getLogger("JSONEventLogger");
+
+        Map<String, Object> details = new HashMap<>();
+        details.put("message", "conflicting detail message");
+        details.put("foo", "bar");
+
+        logger.warn("complex message", details);
+
+        List<String> messages = appender.getMessages();
+        assertEquals(1, messages.size());
+
+        String rawMessage = messages.get(0);
+        assertEquals(1, rawMessage.split("\"message\"", -1).length - 1);
+        assertFalse(rawMessage.contains("\"message\":\"conflicting detail message\""));
+
+        Map<String, Object> loggedMessage =
+            ObjectMappers.JSON_MAPPER.readValue(rawMessage, Map.class);
+        Map<String, Object> logEvent = (Map<String, Object>) loggedMessage.get("logEvent");
+
+        assertEquals("complex message", logEvent.get("message"));
+        assertEquals("bar", logEvent.get("foo"));
+    }
 
     @Test
     @SuppressWarnings("unchecked")
