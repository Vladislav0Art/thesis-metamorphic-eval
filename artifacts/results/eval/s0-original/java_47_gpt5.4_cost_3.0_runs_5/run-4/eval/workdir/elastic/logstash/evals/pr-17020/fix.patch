+package org.logstash.common;
+
+import org.jruby.RubyString;
+import org.jruby.runtime.ThreadContext;
+import org.junit.Before;
+import org.junit.Test;
+
+import static org.junit.Assert.assertArrayEquals;
+import static org.logstash.RubyUtil.BUFFERED_TOKENIZER;
+import static org.logstash.RubyUtil.RUBY;
+
+public class BufferedTokenizerExtTest {
+
+    private ThreadContext context;
+    private BufferedTokenizerExt subject;
+
+    @Before
+    public void setUp() {
+        context = RUBY.getCurrentContext();
+        subject = new BufferedTokenizerExt(RUBY, BUFFERED_TOKENIZER);
+    }
+
+    @Test
+    public void testExtractAndFlushPreservesStringEncodingBytes() {
+        RubyString rubyString = RubyString.newString(RUBY, new byte[]{(byte) 0xA3});
+        RubyString iso88591 = (RubyString) rubyString.force_encoding(
+            context,
+            RUBY.newString("ISO8859-1")
+        );
+
+        subject.extract(context, iso88591);
+
+        RubyString flushed = (RubyString) subject.flush(context);
+        assertArrayEquals(new byte[]{(byte) 0xA3}, flushed.getBytes());
+    }
+}
