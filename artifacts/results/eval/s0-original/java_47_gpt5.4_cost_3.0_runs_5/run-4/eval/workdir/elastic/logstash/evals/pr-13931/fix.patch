+        private RetryTrackingFileCheckpointIO(Path dirPath, boolean retry, int failuresBeforeSuccess) {
+            super(dirPath, retry);
+            this.failuresBeforeSuccess = failuresBeforeSuccess;
+        }
+
+        @Override
+        protected void move(Path source, Path target) throws IOException {
