+            if (moveAttempts <= failuresBeforeSuccess) {
+                throw new AccessDeniedException(source.toString(), target.toString(), "simulated");
+            }
+            super.move(source, target);
+        }
+
+        @Override
+        protected void sleep(long millis) {
+            sleepDurations.add(millis);
+        }
