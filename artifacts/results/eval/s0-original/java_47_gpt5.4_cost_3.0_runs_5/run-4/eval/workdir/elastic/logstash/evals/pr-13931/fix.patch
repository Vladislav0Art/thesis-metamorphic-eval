+    private void moveWithRetry(Path tmpPath, Path targetPath) throws IOException {
+        if (!retry) {
+            try {
+                move(tmpPath, targetPath);
+            } catch (IOException ex) {
+                logger.error("Error writing checkpoint: " + ex);
+                throw ex;
+            }
+            return;
+        }
+
+        long backoffMillis = MOVE_RETRY_INITIAL_BACKOFF_MILLIS;
+        for (int attempt = 0; attempt <= MOVE_RETRY_COUNT; attempt++) {
+            try {
+                move(tmpPath, targetPath);
+                return;
+            } catch (AccessDeniedException ex) {
+                if (attempt == MOVE_RETRY_COUNT) {
+                    logger.error("Aborting after {} retries writing checkpoint: {}", MOVE_RETRY_COUNT, ex.toString());
+                    throw ex;
+                }
+                logger.warn(
+                    "Access denied moving checkpoint file from {} to {}. Retrying attempt {}/{} after {}ms",
+                    tmpPath, targetPath, attempt + 1, MOVE_RETRY_COUNT, backoffMillis
+                );
+                sleep(backoffMillis);
+                backoffMillis = Math.min(backoffMillis * 2, MOVE_RETRY_MAX_BACKOFF_MILLIS);
+            }
+        }
+    }
+
+    protected void move(Path source, Path target) throws IOException {
+        Files.move(source, target, StandardCopyOption.ATOMIC_MOVE);
+    }
+
+    protected void sleep(long millis) throws IOException {
+        try {
+            Thread.sleep(millis);
+        } catch (InterruptedException ex) {
+            Thread.currentThread().interrupt();
+            throw new IOException("Interrupted while retrying checkpoint move", ex);
+        }
+    }
