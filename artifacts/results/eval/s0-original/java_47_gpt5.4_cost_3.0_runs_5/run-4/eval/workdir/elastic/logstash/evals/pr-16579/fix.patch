diff --git a/logstash-core/spec/logstash/util/buftok_spec.rb b/logstash-core/spec/logstash/util/buftok_spec.rb
index cccb9c476..7849ae6d3 100644
--- a/logstash-core/spec/logstash/util/buftok_spec.rb
+++ b/logstash-core/spec/logstash/util/buftok_spec.rb
@@ -57,4 +57,16 @@ describe  FileWatch::BufferedTokenizer  do
       expect(subject.extract("foo||bar")).to eq(["foo"])
     end
   end
+
+  context 'with size limit' do
+    subject { FileWatch::BufferedTokenizer.new("\n", 10) }
+
+    it "drops the oversized buffered payload and resumes from after the next delimiter" do
+      expect(subject.extract("12345")).to eq([])
+
+      expect { subject.extract("678901\nok") }.to raise_error(IllegalStateException, "input buffer full")
+
+      expect(subject.extract("ay\n")).to eq(["okay"])
+    end
+  end
 end
