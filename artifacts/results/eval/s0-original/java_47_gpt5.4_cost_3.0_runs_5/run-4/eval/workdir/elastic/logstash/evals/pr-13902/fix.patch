+        private final List<Long> sleepDurations = new ArrayList<>();
+        private int moveAttempts = 0;
+
+        private RetryingFileCheckpointIO(Path dirPath, boolean retry, int failuresBeforeSuccess) {
+            super(dirPath, retry);
+            this.failuresBeforeSuccess = failuresBeforeSuccess;
+        }
+
+        @Override
+        void move(Path source, Path target) throws IOException {
+            moveAttempts++;
+            if (moveAttempts <= failuresBeforeSuccess) {
