+package org.mockito.java21;
+
+import java.util.List;
+import org.junit.Test;
+
+import static org.assertj.core.api.Assertions.assertThat;
+import static org.mockito.Mockito.spy;
+
+public class RecordSpyWithGenericSpyTest {
+
+    @Test
+    public void spying_generic_type_does_not_break_record_spy() {
+        List<String> genericSpy = spy(List.of("item A", "item B"));
+
+        ExampleRecord exampleRecord = spy(new ExampleRecord("some value"));
+
+        assertThat(genericSpy).containsExactly("item A", "item B");
+        assertThat(exampleRecord.someParameter()).isEqualTo("some value");
+    }
+
+    record ExampleRecord(String someParameter) {}
+}
