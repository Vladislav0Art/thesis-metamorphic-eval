+  @Test
+  public void testNextFieldNameObjectTrailingComma() throws Exception {
+    String json = "{\"a\": true,}";
+
+    JsonParser p = createParser(factory, mode, json);
+
+    assertEquals(JsonToken.START_OBJECT, p.nextToken());
+
+    assertEquals("a", p.nextFieldName());
+    assertToken(JsonToken.VALUE_TRUE, p.nextToken());
+
+    if (features.contains(Feature.ALLOW_TRAILING_COMMA)) {
+      assertNull(p.nextFieldName());
+      assertToken(JsonToken.END_OBJECT, p.getCurrentToken());
+      assertEnd(p);
+    } else {
+      assertUnexpected(p, '}');
+    }
+    p.close();
+  }
 
