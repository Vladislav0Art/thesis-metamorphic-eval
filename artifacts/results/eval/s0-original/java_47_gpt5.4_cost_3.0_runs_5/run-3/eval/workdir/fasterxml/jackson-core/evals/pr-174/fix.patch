@@ -184,6 +184,24 @@ public class JsonPointer
         return _nextSegment;
     }
 
+    /**
+     * Accessor for getting the leaf segment of this pointer, if any; returns
+     * the last non-empty segment as a pointer. For root pointer, will return
+     * null.
+     *
+     * @since 2.6
+     */
+    public JsonPointer last() {
+        if (this == EMPTY) {
+            return null;
+        }
+        JsonPointer current = this;
+        while (current._nextSegment != EMPTY) {
+            current = current._nextSegment;
+        }
+        return current;
+    }
+
