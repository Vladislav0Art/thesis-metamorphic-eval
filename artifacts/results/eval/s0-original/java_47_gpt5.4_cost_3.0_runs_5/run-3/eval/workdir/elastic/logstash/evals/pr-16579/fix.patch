@@ -57,4 +57,15 @@ describe  FileWatch::BufferedTokenizer  do
       expect(subject.extract("foo||bar")).to eq(["foo"])
     end
   end
+
+  context 'with size limit' do
+    subject { FileWatch::BufferedTokenizer.new("\n", 9) }
+
+    it "discards oversized payload when restarted after a buffer full error" do
+      expect(subject.extract("12345")).to eq([])
+      expect { subject.extract("67890\nok\n") }.to raise_error(Java::JavaLang::IllegalStateException, "input buffer full")
