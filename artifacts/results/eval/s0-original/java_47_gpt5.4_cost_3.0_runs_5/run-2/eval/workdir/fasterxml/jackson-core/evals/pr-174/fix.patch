+    /**
+     * Accessor for getting a pointer that contains only the leaf segment
+     * of the current pointer. For root pointer, will return null.
+     */
+    public JsonPointer last() {
+        if (_nextSegment == null) {
+            return null;
+        }
+        JsonPointer current = this;
+        while (current._nextSegment != EMPTY) {
+            current = current._nextSegment;
