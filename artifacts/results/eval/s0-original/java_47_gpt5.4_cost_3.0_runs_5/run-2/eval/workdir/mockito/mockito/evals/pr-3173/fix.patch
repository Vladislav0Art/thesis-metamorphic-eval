+++ b/subprojects/java21/src/test/java/org/mockito/java21/GenericSpyWithRecordAnnotationTest.java
@@ -0,0 +1,40 @@
+/*
+ * Copyright (c) 2024 Mockito contributors
+ * This program is made available under the terms of the MIT License.
+ */
+package org.mockito.java21;
+
+import java.util.List;
+import org.junit.After;
+import org.junit.Test;
+import org.mockito.MockitoAnnotations;
+import org.mockito.Spy;
+import org.mockito.exceptions.base.MockitoException;
+
+import static org.assertj.core.api.Assertions.assertThat;
+
+public class GenericSpyWithRecordAnnotationTest {
+
+    @Spy private final List<String> genericSpy = List.of("item A", "item B");
+
+    @Spy private ExampleRecord exampleRecord = new ExampleRecord("some value");
+
+    private AutoCloseable mocks;
+
+    @After
+    public void tearDown() throws Exception {
+        if (mocks != null) {
+            mocks.close();
+        }
+    }
+
+    @Test
+    public void generic_spy_does_not_break_record_spy() throws Exception {
+        mocks = MockitoAnnotations.openMocks(this);
+
+        assertThat(genericSpy).containsExactly("item A", "item B");
+        assertThat(exampleRecord.someParameter()).isEqualTo("some value");
+    }
+
+    record ExampleRecord(String someParameter) {}
+}
