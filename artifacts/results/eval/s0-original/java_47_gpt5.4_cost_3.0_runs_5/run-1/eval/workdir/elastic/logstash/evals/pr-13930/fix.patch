+    private void moveWithRetry(Path source, Path target) throws IOException {
+        AccessDeniedException lastError = null;
+        final int maxAttempts = retry ? MAX_MOVE_RETRIES + 1 : 1;
+        long delay = INITIAL_RETRY_DELAY_MILLIS;
+
+        for (int attempt = 1; attempt <= maxAttempts; attempt++) {
+            try {
+                moveFile(source, target);
+                return;
+            } catch (AccessDeniedException ex) {
+                lastError = ex;
+                if (attempt == maxAttempts) {
+                    logger.error("Aborting after {} failed attempt(s) writing checkpoint: {}", attempt, ex.toString());
+                    throw ex;
+                }
+
+                logger.warn(
+                    "Retrying checkpoint move after failed attempt {}/{}: {}",
+                    attempt,
+                    maxAttempts,
+                    ex.toString()
+                );
+
+                try {
+                    sleepBeforeRetry(delay);
+                } catch (InterruptedException interrupted) {
+                    Thread.currentThread().interrupt();
+                    logger.error("Interrupted while retrying checkpoint move after {} failed attempt(s)", attempt, interrupted);
+                    throw ex;
+                }
+                delay = Math.min(delay * 2, MAX_RETRY_DELAY_MILLIS);
+            }
+        }
+
+        throw lastError;
+    }
