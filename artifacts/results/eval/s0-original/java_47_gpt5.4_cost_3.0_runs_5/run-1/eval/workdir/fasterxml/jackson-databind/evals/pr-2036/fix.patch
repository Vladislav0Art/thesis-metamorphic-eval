+    public void testUseBaseTypeAsDefaultImpl() throws Exception
+    {
+        String json = "{\"name\":\"name\"}";
+
+        ObjectMapper mapper = new ObjectMapper();
+        try {
+            mapper.readValue(json, BaseTypeAsDefaultImpl.class);
+            fail("Should not pass without type information");
+        } catch (Exception e) {
+            verifyException(e, "missing type id property");
+        }
 
+        mapper = new ObjectMapper();
+        mapper.configure(MapperFeature.USE_BASE_TYPE_AS_DEFAULT_IMPL, true);
+        BaseTypeAsDefaultImpl result = mapper.readValue(json, BaseTypeAsDefaultImpl.class);
+        assertNotNull(result);
+        assertEquals("name", result.name);
+    }
