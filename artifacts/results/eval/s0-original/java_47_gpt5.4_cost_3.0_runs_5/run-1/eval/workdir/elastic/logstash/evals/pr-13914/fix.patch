diff --git a/build.gradle b/build.gradle
index 7e4c7a868..cb65d8e69 100644
--- a/build.gradle
+++ b/build.gradle
@@ -860,6 +860,19 @@ tasks.register("copyJdk", Copy) {
     description = "Download, unpack and copy the JDK"
     // CLI project properties: -Pjdk_bundle_os=[windows|linux|darwin] -Pjdk_arch=[arm64|x86_64]
     doLast {
+        File releaseFile = file("${project.ext.jdkBundlingDirectory}/release")
+        if (!releaseFile.exists()) {
+            releaseFile = file("${project.ext.jdkBundlingDirectory}/Contents/Home/release")
+        }
+        if (releaseFile.exists()) {
+            String bundledJdkVersion = releaseFile.readLines().findResult { line ->
+                def matcher = line =~ /^IMPLEMENTOR_VERSION="(.*)"$/
+                matcher.matches() ? matcher[0][1] : null
+            }
+            if (bundledJdkVersion != null) {
+                file("${releaseFile.parentFile}/VERSION").text = "${bundledJdkVersion}\n"
+            }
+        }
         System.out.println "Download location is ${project.ext.jdkDownloadLocation}, Decompressing ${project.ext.jdkDirectory} to \"${project.ext.jdkBundlingDirectory}\""
     }
 }
