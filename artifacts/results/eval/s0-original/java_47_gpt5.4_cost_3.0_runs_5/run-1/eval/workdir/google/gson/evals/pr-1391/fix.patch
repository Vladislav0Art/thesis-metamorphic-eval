@@ -108,6 +108,26 @@ public class RecursiveTypesResolveTest extends TestCase {
     TypeAdapter<TestType2> adapter = new Gson().getAdapter(TestType2.class);
     assertNotNull(adapter);
   }
+
+  private enum TestEnum {
+    ONE, TWO, THREE
+  }
+
+  private static class TestEnumSetCollection extends SetCollection<TestEnum> {}
+
+  private static class SetCollection<T> extends BaseCollection<T, java.util.Set<T>> {}
+
+  private static class BaseCollection<U, C extends java.util.Collection<U>> {
+    public C collection;
+  }
+
+  public void testTypeVariableReferencedMultipleTimesResolvesCorrectly() {
+    TestEnumSetCollection result =
+        new Gson().fromJson("{\"collection\":[\"ONE\",\"THREE\"]}", TestEnumSetCollection.class);
+
+    Object first = result.collection.iterator().next();
+    assertEquals(TestEnum.class, first.getClass());
+  }
