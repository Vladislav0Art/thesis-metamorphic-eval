diff --git a/logstash-core/spec/logstash/util/buftok_spec.rb b/logstash-core/spec/logstash/util/buftok_spec.rb
index cccb9c476..958213496 100644
--- a/logstash-core/spec/logstash/util/buftok_spec.rb
+++ b/logstash-core/spec/logstash/util/buftok_spec.rb
@@ -57,4 +57,21 @@ describe  FileWatch::BufferedTokenizer  do
       expect(subject.extract("foo||bar")).to eq(["foo"])
     end
   end
+
+  context 'with size limit' do
+    subject { FileWatch::BufferedTokenizer.new(delimiter, size_limit) }
+
+    let(:delimiter) { "\n" }
+    let(:size_limit) { 10 }
+
+    it "drops buffered data until the next delimiter after buffer full" do
+      expect(subject.extract("12345")).to eq([])
+
+      expect { subject.extract("678901\nok\n") }
+        .to raise_error(Java::JavaLang::IllegalStateException, "input buffer full")
+
+      expect(subject.extract("next\n")).to eq(["ok", "next"])
+    end
+
+  end
 end
