+  public void testJsonSerializerDeserializerBasedJsonAdapterNullSafeFalse() {
+    Gson gson = new Gson();
+
+    String json = gson.toJson(new Computer3(null));
+    assertEquals("{\"user\":\"serialized-null\"}", json);
+
+    Computer3 computer = gson.fromJson("{\"user\":null}", Computer3.class);
+    assertEquals("deserialized-null", computer.user.name);
+  }
+
+  private static final class Computer3 {
+    @JsonAdapter(value = NullSafeFalseUserAdapter.class, nullSafe = false) final User3 user;
+    Computer3(User3 user) {
+      this.user = user;
+    }
+  }
+
+  private static final class User3 {
+    final String name;
+    private User3(String name) {
+      this.name = name;
+    }
+  }
+
+  private static final class NullSafeFalseUserAdapter
+      implements JsonSerializer<User3>, JsonDeserializer<User3> {
+    @Override
+    public JsonElement serialize(User3 src, Type typeOfSrc, JsonSerializationContext context) {
+      return new JsonPrimitive(src == null ? "serialized-null" : src.name);
+    }
+
+    @Override
+    public User3 deserialize(JsonElement json, Type typeOfT, JsonDeserializationContext context)
+        throws JsonParseException {
+      return json.isJsonNull() ? new User3("deserialized-null") : new User3(json.getAsString());
+    }
+  }
