+package org.mockitousage.bugs.deepstubs;
+
+import static org.junit.Assert.assertEquals;
+import static org.mockito.Mockito.RETURNS_DEEP_STUBS;
+import static org.mockito.Mockito.mock;
+import static org.mockito.Mockito.when;
+
+import org.junit.Test;
+
+public class DeepStubReturnsEnumJava21Test {
+
+    interface Board {
+        Piece getPiece();
+    }
+
+    interface Piece {
+        PieceType getPieceType();
+    }
+
+    enum PieceType {
+        SQUARE(2.5d);
+
+        private final double costPerPieceSpace;
+
+        PieceType(double costPerPieceSpace) {
+            this.costPerPieceSpace = costPerPieceSpace;
+        }
+
+        double getCostPerPieceSpace() {
+            return costPerPieceSpace;
+        }
+    }
+
+    @Test
+    public void deep_stub_can_stub_method_on_enum_return_type() {
+        Board board = mock(Board.class, RETURNS_DEEP_STUBS);
+
+        when(board.getPiece().getPieceType().getCostPerPieceSpace()).thenReturn(2.5d);
+
+        assertEquals(2.5d, board.getPiece().getPieceType().getCostPerPieceSpace(), 0.0d);
+    }
+}
