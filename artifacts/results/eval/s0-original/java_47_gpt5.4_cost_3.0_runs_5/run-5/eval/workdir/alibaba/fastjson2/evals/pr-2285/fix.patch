+
+    @JSONType(serializer = AlarmStatusWriter.class)
+    public enum AlarmStatus {
+        RUNNING("启用", 1),
+        STOP("停止", 2);
+
+        public final String label;
+        public final int value;
+
+        AlarmStatus(String label, int value) {
+            this.label = label;
+            this.value = value;
+        }
+    }
+
+    public static class AlarmStatusWriter
+            implements ObjectWriter<AlarmStatus> {
+        @Override
+        public void write(JSONWriter jsonWriter, Object object, Object fieldName, Type fieldType, long features) {
+            AlarmStatus status = (AlarmStatus) object;
+
+            jsonWriter.startObject();
+
+            jsonWriter.writeName("label");
+            jsonWriter.writeColon();
+            jsonWriter.writeString(status.label);
+
+            jsonWriter.writeName("value");
+            jsonWriter.writeColon();
+            jsonWriter.writeInt32(status.value);
+
+            jsonWriter.endObject();
+        }
+    }
