+    @Test
+    public void testFieldTypeSerializer() {
+        AppDto app = new AppDto();
+        app.setAlarmStatus(AlarmStatus.RUNNING);
+
+        assertEquals("{\"alarmStatus\":{\"label\":\"启用\",\"value\":1}}", JSON.toJSONString(app));
+    }
+
+    @Test
+    public void testFieldTypeSerializer1() {
+        AppDto app = new AppDto();
+        app.setAlarmStatus(AlarmStatus.RUNNING);
+
+        for (ObjectWriterCreator creator : TestUtils.writerCreators()) {
+            ObjectWriter objectWriter = creator.createObjectWriter(AppDto.class);
+            JSONWriter jsonWriter = JSONWriter.of();
+            objectWriter.write(jsonWriter, app);
+            String str = jsonWriter.toString();
+            assertEquals("{\"alarmStatus\":{\"label\":\"启用\",\"value\":1}}", str);
+        }
+    }
+
+    @Test
+    public void testGetterTypeSerializer() {
+        GetterOnlyDto app = new GetterOnlyDto();
+
+        assertEquals("{\"alarmStatus\":{\"label\":\"启用\",\"value\":1}}", JSON.toJSONString(app));
+    }
+
+    @Test
+    public void testGetterTypeSerializer1() {
+        GetterOnlyDto app = new GetterOnlyDto();
+
+        for (ObjectWriterCreator creator : TestUtils.writerCreators()) {
+            ObjectWriter objectWriter = creator.createObjectWriter(GetterOnlyDto.class);
+            JSONWriter jsonWriter = JSONWriter.of();
+            objectWriter.write(jsonWriter, app);
