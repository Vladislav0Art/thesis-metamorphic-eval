+ * This program is made available under the terms of the MIT License.
+ */
+package org.mockito.java21;
+
+import static org.junit.Assert.assertEquals;
+
+import java.util.List;
+
+import org.junit.After;
+import org.junit.Test;
+import org.mockito.Mockito;
+import org.mockito.MockitoAnnotations;
+import org.mockito.Spy;
+public class GenericSpyRecordTest {
+
+    private AutoCloseable mocks;
+
+    @Spy private final List<String> genericSpy = List.of("item A", "item B");
+
+    @Spy private ExampleRecord exampleRecord = new ExampleRecord("some value");
+
+    @After
+    public void releaseMocks() throws Exception {
+        if (mocks != null) {
+            mocks.close();
+        }
+    }
+
+    @Test
+    public void should_keep_record_state_when_spied_directly() {
+        ExampleRecord record = Mockito.spy(new ExampleRecord("some value"));
+
+        assertEquals("some value", record.someParameter());
+    }
+
+    @Test
+    public void should_keep_record_state_when_spying_generic_instance_first() {
+        List<String> ignored = Mockito.spy(List.of("item A", "item B"));
+        ExampleRecord record = Mockito.spy(new ExampleRecord("some value"));
+
+        assertEquals("some value", record.someParameter());
+    }
+
+    @Test
+    public void should_keep_record_state_when_generic_spy_is_present() {
+        mocks = MockitoAnnotations.openMocks(this);
+
+        assertEquals("some value", exampleRecord.someParameter());
+    }
+
+    record ExampleRecord(String someParameter) {}
+}
diff --git a/subprojects/junitJupiterInlineMockMakerExtensionTest/src/test/java/org/mockitousage/GenericSpyWithRecordTest.java b/subprojects/junitJupiterInlineMockMakerExtensionTest/src/test/java/org/mockitousage/GenericSpyWithRecordTest.java
