@@ -0,0 +1,41 @@
+/*
+ * Copyright (c) 2024 Mockito contributors
+ * This program is made available under the terms of the MIT License.
+ */
+package org.mockitousage;
+
+import static org.assertj.core.api.Assertions.assertThat;
+
+import java.util.List;
+
+import org.junit.jupiter.api.Test;
+import org.junit.jupiter.api.extension.ExtendWith;
+import org.mockito.Spy;
+import org.mockito.junit.jupiter.MockitoExtension;
+
+@ExtendWith(MockitoExtension.class)
+class GenericSpyWithRecordTest {
+
+    @Spy
+    private final List<String> genericSpy = List.of("item A", "item B");
+
+    @Spy
+    private FinalClass example = new FinalClass("some value");
+
+    @Test
+    void keeps_final_spy_state_when_generic_spy_is_present() {
+        assertThat(example.someParameter()).isEqualTo("some value");
+    }
+
+    private static final class FinalClass {
+        private final String someParameter;
+
+        private FinalClass(String someParameter) {
+            this.someParameter = someParameter;
+        }
+
+        private String someParameter() {
+            return someParameter;
+        }
+    }
+}
